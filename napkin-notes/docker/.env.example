# Domain for Traefik routing and TLS
DOMAIN=napkin-notes.example.com

# Let's Encrypt email for ACME certificates
ACME_EMAIL=admin@example.com

# Database
DB_USER=napkin
DB_PASSWORD=change-me-in-production
DB_NAME=napkin_notes

# JWT signing secret
JWT_SECRET=change-me-to-a-random-string

# Storage path (inside container)
STORAGE_PATH=/data/storage
